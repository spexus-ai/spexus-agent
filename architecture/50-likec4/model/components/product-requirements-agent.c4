model {
  cli_router = component "CLI Command Router"
  config_manager = component "Config Manager"
  project_registry = component "Project Registry Service"
  runtime_orchestrator = component "Runtime Startup Orchestrator"
  socket_transport = component "Slack Socket Transport"
  slack_api = component "Slack Web API Client"
  invocation_preparer = component "Invocation Preparer"
  turn_coordinator = component "Turn Coordinator"
  execution_manager = component "Execution Manager"
  renderer = component "Slack Thread Renderer"
  acpx_adapter = component "ACPX CLI Adapter"
  sqlite_store_adapter = component "SQLite Store Adapter"

  cli_router -> config_manager "config commands"
  cli_router -> project_registry "project commands"
  cli_router -> runtime_orchestrator "runtime commands"
  project_registry -> config_manager "load base workspace and slack auth"
  project_registry -> slack_api "provision channels"
  project_registry -> sqlite_store_adapter "persist project registry"
  project_registry -> git_cli "inspect git remotes"
  project_registry -> repos "inspect local repositories"
  runtime_orchestrator -> socket_transport "consume invocations"
  runtime_orchestrator -> invocation_preparer "map channel and thread context"
  runtime_orchestrator -> turn_coordinator "claim and persist execution state"
  runtime_orchestrator -> execution_manager "schedule accepted work"
  runtime_orchestrator -> acpx_adapter "send prompts"
  runtime_orchestrator -> renderer "render ACPX output"
  runtime_orchestrator -> slack_api "post slash/turn replies"
  runtime_orchestrator -> sqlite_store_adapter "load and update runtime state"
  turn_coordinator -> sqlite_store_adapter "thread locks and executions"
  execution_manager -> turn_coordinator "start and complete queued executions"
  renderer -> slack_api "append thread messages"
  socket_transport -> slack "websocket"
  slack_api -> slack "https api"
  acpx_adapter -> acpx "subprocess"
  acpx_adapter -> repos "execute in repository working tree"
  sqlite_store_adapter -> local_sqlite_db "sql"
}
